target/

### IntelliJ IDEA ###
# IntelliJ compiled output directory (when not using Maven)
out/

# Module files (machine-specific, regenerated by IDE)
*.iml

# Local IDE workspace state (not shareable)
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries/
.idea/shelf/

# Sensitive / environment-specific IntelliJ settings
.idea/dataSources/
.idea/dataSources.ids
.idea/dataSources.local.xml
.idea/sqlDataSources.xml
.idea/dynamic.classpath
.idea/gradle.xml

